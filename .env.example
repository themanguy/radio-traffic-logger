# Copy to .env and fill in your values

# Required: HTTP audio stream URL (MP3 or AAC)
STREAM_URL=http://example.com/stream.mp3

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=small

# Transcription language (ISO 639-1)
WHISPER_LANGUAGE=en

# Override the FENZ prompt priming (leave blank to use default)
# WHISPER_INITIAL_PROMPT=

# VAD sensitivity (0.0–1.0, higher = less sensitive)
VAD_THRESHOLD=0.5

# Minimum speech duration before a segment is kept (milliseconds)
VAD_MIN_SPEECH_DURATION_MS=250

# Silence gap needed to close a segment (milliseconds)
VAD_MIN_SILENCE_DURATION_MS=400

# SQLite database path
DB_PATH=transmissions.db

# Comma-separated keywords to flag in the log (case-insensitive)
# KEYWORD_WATCHLIST=structure fire,persons reported,mayday,MVA

# Seconds to wait before reconnecting after a stream drop
RECONNECT_DELAY_SECONDS=5

# ── Slack notifications (optional) ──────────────────────────────────────────
# Default catch-all webhook (used if SLACK_WEBHOOK_FENZ is not set)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# FENZ-specific channel
# SLACK_WEBHOOK_FENZ=https://hooks.slack.com/services/XXX/YYY/ZZZ
